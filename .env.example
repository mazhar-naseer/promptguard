# --- Core ---
APP_ENV=development
SECRET_KEY=change-this-to-a-long-random-string
DATABASE_URL=sqlite:///./data/promptguard.db

# --- Auth ---
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Seeded on first boot if no admin user exists yet
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ADMIN_EMAIL=admin@example.com

# --- Detection config ---
RULES_CONFIG_PATH=app/config/rules.json
SCORING_CONFIG_PATH=app/config/scoring_weights.json
MAX_PROMPT_LENGTH=8000

# --- LLM judge (optional second-opinion layer) ---
LLM_JUDGE_ENABLED=false
LLM_JUDGE_API_KEY=
LLM_JUDGE_API_URL=https://api.openai.com/v1/chat/completions
LLM_JUDGE_MODEL=gpt-4o-mini

# --- Rate limiting ---
RATE_LIMIT_ANALYST=60/minute
RATE_LIMIT_ANONYMOUS=10/minute
